# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/livekit-agent/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# build logs / dev artifacts
build_*.log
build_*.txt
tsc_*.log
tsc_*.txt
lint_errors.txt

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# Server scripts with secrets (keep local)
setup-inbound-sip.mjs
restart-agent.sh
start-agent.sh
start-agent-local.sh
deploy-agent.sh
setup-agent-service.sh

# Debug/test scripts (low value)
check-sip-trunk.mjs
fix-sip-trunk.mjs
fix-network.sh
test-sip-call.mjs

# typescript
*.tsbuildinfo
next-env.d.ts
.aider*

# database
*.db
*.sqlite

# Allow access to Prisma types for development
!node_modules/@prisma/client
.env*.local

# Sentry Config File
.env.sentry-build-plugin
