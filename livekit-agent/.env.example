# LiveKit Server
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
NEXT_PUBLIC_APP_URL=https://earlymark.ai
VOICE_AGENT_WEBHOOK_SECRET=your_voice_agent_webhook_secret
EARLYMARK_INBOUND_PHONE_NUMBER=+61400000000

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_key

# DeepInfra (LLM — Llama-3.3-70B-Instruct via OpenAI-compatible API)
DEEPINFRA_API_KEY=your_deepinfra_key

# Groq (Preferred for all voice calls whenever a key is present)
GROQ_API_KEY=your_groq_key
EARLYMARK_VOICE_LLM_PROVIDER=groq
EARLYMARK_VOICE_LLM_MODEL=llama-3.3-70b-versatile
EARLYMARK_VOICE_LLM_TEMPERATURE=0.1
EARLYMARK_VOICE_LLM_MAX_COMPLETION_TOKENS=64
INBOUND_VOICE_LLM_MAX_COMPLETION_TOKENS=48
INBOUND_VOICE_MIN_INTERRUPTION_WORDS=1

# Cartesia (Text-to-Speech)
CARTESIA_API_KEY=your_cartesia_key
